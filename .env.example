PREDICTUS_API_BASE_URL=https://api.predictus.com.br/predictus-api
PREDICTUS_TIMEOUT_MS=30000

# Judit
JUDIT_API_KEY=
JUDIT_REQUESTS_URL=https://requests.prod.judit.io
JUDIT_LAWSUITS_URL=https://lawsuits.production.judit.io
JUDIT_TRACKING_URL=https://tracking.prod.judit.io
JUDIT_TIMEOUT_MS=30000
JUDIT_CACHE_TTL_DAYS=7

# DataJud (CNJ public API — free, public key from CNJ wiki)
DATAJUD_API_KEY=cDZHYzlZa0JadVREZDJCendQbXY6SkJlTzNjLV9TRENyQk1RdnFKZGRQdw==
DATAJUD_BASE_URL=https://api-publica.datajud.cnj.jus.br
DATAJUD_TIMEOUT_MS=15000

# Orchestration
PRIMARY_PROVIDER=judit
ORCHESTRATION_STRATEGY=race
RACE_TIMEOUT_MS=45000
POLL_INTERVAL_MS=5000
MAX_POLL_ATTEMPTS=60
ENABLE_MERGE=true

# Circuit Breaker
CB_FAILURE_THRESHOLD=5
CB_RESET_TIMEOUT_MS=60000

# Retry
RETRY_MAX_ATTEMPTS=3
RETRY_BASE_DELAY_MS=1000
RETRY_MAX_DELAY_MS=30000

# Webhook
WEBHOOK_BASE_URL=
WEBHOOK_SECRET=

# Consumer Auth
API_AUTH_TOKEN=
API_ACCESS_KEY=

# AppSheet Webhook
APPSHEET_WEBHOOK_URL=
